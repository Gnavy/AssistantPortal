/* 聊天页面样式 - 移植自 ChatPage.tsx */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
  overflow: hidden;
  box-sizing: border-box;
}

/* 自定义顶栏 */
.custom-header {
  flex-shrink: 0;
  background-color: #f5f7fa;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 72rpx;
}

.logo-box {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  border: 1rpx dashed rgba(0, 0, 0, 0.25);
  background-color: #fff;
  color: #333;
  font-size: 20rpx;
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}

/* 与 logo-box 同宽，标题保持居中 */
.header-spacer {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.welcome-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  height: 100%;
}

.list-footer-spacer {
  height: 24rpx;
}

.message-row {
  display: flex;
  margin-bottom: 24rpx;
}

.row-right {
  justify-content: flex-end;
}

.row-left {
  justify-content: flex-start;
}

.user-bubble {
  max-width: 85%;
  border-radius: 28rpx;
  border-bottom-right-radius: 10rpx;
  padding: 18rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #fff;
  background-color: #333;
  word-break: break-all;
}

.assistant-bubble {
  max-width: 88%;
  border-radius: 28rpx;
  border-bottom-left-radius: 10rpx;
  background-color: #f0f2f5;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #222;
}

.bubble-content {
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.typing-cursor {
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  margin-left: 8rpx;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 4rpx;
  vertical-align: middle;
  animation: pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.bubble-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  color: #333;
}

.copy-btn {
  padding: 6rpx 8rpx;
}

.copy-text {
  font-size: 24rpx;
  color: #333;
}

/* 底栏 */
.bottom-bar {
  flex-shrink: 0;
  background-color: #f5f7fa;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-top: 16rpx;
}

.input-shell {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background-color: #fff;
  padding: 16rpx 20rpx;
}

.icon-tool {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.tool-icon {
  font-size: 40rpx;
  color: #666;
  line-height: 1;
  font-weight: 300;
}

.icon-tool-phone {
  margin-left: 4rpx;
}

.tool-icon-phone {
  font-size: 44rpx;
  color: #333;
}

.text-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 30rpx;
  color: #333;
  padding: 0 8rpx;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0;
  }
}
